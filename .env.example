# =====================================================
# StockUp - Environment Variables Template
# =====================================================
# Salin file ini menjadi .env dan isi dengan nilai yang sesuai.
# JANGAN commit file .env ke repository!
# =====================================================

# ==================== DATABASE ====================
DATABASE_URL="mysql://stockup_user:stockup_pass@localhost:3306/stockup_dev"

# ==================== JWT ====================
JWT_ACCESS_SECRET="your-access-secret-key-min-32-chars"
JWT_REFRESH_SECRET="your-refresh-secret-key-min-32-chars"
JWT_ACCESS_EXPIRATION="15m"
JWT_REFRESH_EXPIRATION="7d"

# ==================== CLOUDINARY ====================
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ==================== RESEND (Email) ====================
RESEND_API_KEY="re_your_resend_api_key"
EMAIL_FROM="noreply@yourdomain.com"

# ==================== APPLICATION ====================
PORT=3001
FRONTEND_URL="http://localhost:5173"
NODE_ENV="development"

# ==================== ADMIN SEED ====================
ADMIN_EMAIL="admin@stockup.id"
ADMIN_PASSWORD="StockUp@Admin2026"
ADMIN_FULL_NAME="StockUp Admin"
